@page "/"
@rendermode InteractiveServer
@inject OnlineChronometer.Services.ChronometerService service

<style>
    .container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 80vh;
    }

    .card {
        background: #1e1e2f;
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        text-align: center;
        color: white;
        width: 350px;
    }

    .time {
        font-size: 48px;
        margin: 20px 0;
        font-weight: bold;
    }

    .buttons button {
        margin: 5px;
        padding: 10px 15px;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        font-weight: bold;
    }

    .start { background: #28a745; color: white; }
    .pause { background: #ffc107; color: black; }
    .reset { background: #dc3545; color: white; }
    .lap { background: #007bff; color: white; }

    ul {
        list-style: none;
        padding: 0;
        margin-top: 15px;
        max-height: 150px;
        overflow-y: auto;
    }

    li {
        background: #2c2c3e;
        margin: 5px 0;
        padding: 8px;
        border-radius: 8px;
    }
</style>

<div class="container">
    <div class="card">

        <h2>Cronómetro</h2>

        <div class="time">@FormattedTime</div>

        <div class="buttons">
            <button class="start" @onclick="Start">Iniciar</button>
            <button class="pause" @onclick="Pause">Pausar</button>
            <button class="reset" @onclick="Reset">Reiniciar</button>
            <button class="lap" @onclick="Lap">Vuelta</button>
        </div>

        <h4>Vueltas</h4>

        <ul>
            @foreach (var lap in service.Model.Laps)
            {
                <li>@lap</li>
            }
        </ul>

    </div>
</div>

@code {
    private System.Timers.Timer timer;

    private string FormattedTime =>
        $"{service.Model.Time / 60:D2}:{service.Model.Time % 60:D2}";

    protected override void OnInitialized()
    {
        timer = new System.Timers.Timer(1000);
        timer.Elapsed += (s, e) =>
        {
            service.IncrementTime();
            InvokeAsync(StateHasChanged);
        };
        timer.Start();
    }

    void Start() => service.Start();
    void Pause() => service.Pause();
    void Reset() => service.Reset();
    void Lap() => service.AddLap();
}